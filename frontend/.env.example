# Copy to .env.local for local dev, or .env.production for builds.
# Both files are gitignored.
#
# For AWS mode, the easier path is `npm run sync-config` from the repo root
# (after `npx ampx sandbox`) — it writes this file for you from amplify_outputs.json.

# Backend selector.
#   - unset / "false"  -> talk to local Express backend via Vite proxy (/api -> :4000)
#   - "true"           -> use AWS Cognito (Amplify Auth) + the API URL below
VITE_USE_AMPLIFY=false

# --- Only required when VITE_USE_AMPLIFY=true ---
# Generated by `npx ampx sandbox`/`pipeline-deploy` at repo root in
# amplify_outputs.json. Field mapping:
#   auth.user_pool_id          -> VITE_COGNITO_USER_POOL_ID
#   auth.user_pool_client_id   -> VITE_COGNITO_USER_POOL_CLIENT_ID
#   custom.apiUrl              -> VITE_API_URL

# VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/dev/
# VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# VITE_COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
